{
  "repository": "FileUni/FileUni-Project",
  "package": {
    "name": "fileuni",
    "description": "FileUni CLI distributed through npm with on-demand platform binary downloads.",
    "repository_directory": ".github/npm"
  },
  "targets": [
    { "target": "x86_64-unknown-linux-gnu", "os": "linux", "arch": "x64", "libc": "gnu", "binary_name": "fileuni" },
    { "target": "x86_64-unknown-linux-musl", "os": "linux", "arch": "x64", "libc": "musl", "binary_name": "fileuni" },
    { "target": "aarch64-unknown-linux-gnu", "os": "linux", "arch": "arm64", "libc": "gnu", "binary_name": "fileuni" },
    { "target": "aarch64-unknown-linux-musl", "os": "linux", "arch": "arm64", "libc": "musl", "binary_name": "fileuni" },
    { "target": "i686-unknown-linux-gnu", "os": "linux", "arch": "ia32", "libc": "gnu", "binary_name": "fileuni" },
    { "target": "i686-unknown-linux-musl", "os": "linux", "arch": "ia32", "libc": "musl", "binary_name": "fileuni" },
    { "target": "arm-unknown-linux-gnueabi", "os": "linux", "arch": "arm", "libc": "gnu", "binary_name": "fileuni" },
    { "target": "armv7-unknown-linux-musleabihf", "os": "linux", "arch": "arm", "libc": "musl", "binary_name": "fileuni" },
    { "target": "riscv64gc-unknown-linux-gnu", "os": "linux", "arch": "riscv64", "libc": "gnu", "binary_name": "fileuni" },
    { "target": "powerpc64le-unknown-linux-gnu", "os": "linux", "arch": "ppc64", "libc": "gnu", "binary_name": "fileuni" },
    { "target": "x86_64-pc-windows-msvc", "os": "win32", "arch": "x64", "binary_name": "fileuni.exe" },
    { "target": "i686-pc-windows-msvc", "os": "win32", "arch": "ia32", "binary_name": "fileuni.exe" },
    { "target": "x86_64-apple-darwin", "os": "darwin", "arch": "x64", "binary_name": "fileuni" },
    { "target": "aarch64-apple-darwin", "os": "darwin", "arch": "arm64", "binary_name": "fileuni" },
    { "target": "aarch64-linux-android", "os": "android", "arch": "arm64", "binary_name": "fileuni" },
    { "target": "armv7-linux-androideabi", "os": "android", "arch": "arm", "binary_name": "fileuni" },
    { "target": "x86_64-linux-android", "os": "android", "arch": "x64", "binary_name": "fileuni" },
    { "target": "x86_64-unknown-freebsd", "os": "freebsd", "arch": "x64", "binary_name": "fileuni" }
  ]
}
